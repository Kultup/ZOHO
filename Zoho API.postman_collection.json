							"mode": "raw",
							"raw": "{\n  \"organizationId\": \"bebb377a-f070-42b0-a68c-28ade4db6e28\",\n  \"reserveId\": \"95472c6c-ecbd-49b4-8f7f-afea1eb0360d\",\n  \"employeeId\": \"df103a36-9b52-45b9-b911-b8821e5b24d3\"\n}",
